AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=085001782625

# Agent 설정
AGENT_NAME=CodeBuddy-Reviewer
AGENT_DESCRIPTION=코드 리뷰 및 보안 분석 에이전트
FOUNDATION_MODEL=global.anthropic.claude-sonnet-4-6

# IAM Role (Agent가 Bedrock을 호출할 때 사용하는 Role)
AGENT_ROLE_ARN=arn:aws:iam::085001782625:role/AmazonBedrockAgentServiceRole

# Knowledge Base (선택 사항 — 없으면 연결 단계 건너뜀)
KNOWLEDGE_BASE_ID=

# 저장된 Agent/Alias ID (setup 후 자동 기록됨)
AGENT_ID=
AGENT_ALIAS_ID=
